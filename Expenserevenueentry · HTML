<!DOCTYPE html>
<html dir="ltr">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=yes">
  <title>Expense & Revenue Entry</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif; }
    body { background:linear-gradient(135deg,#0b2a4f 0%,#1b3a6b 100%); min-height:100vh; padding:16px; }

    .container { max-width:900px; margin:0 auto; background:white; border-radius:30px; box-shadow:0 20px 60px rgba(0,20,40,0.4); overflow:visible; }

    /* HEADER */
    .header { background:#0b2447; color:white; padding:16px 30px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px; border-bottom:3px solid #f4c542; border-radius:30px 30px 0 0; }
    .header h2 { color:#fad57e; font-size:20px; display:flex; align-items:center; gap:8px; }
    .user-info { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
    .user-badge { background:rgba(255,255,255,0.1); padding:6px 16px; border-radius:40px; border:1px solid #ffd966; color:#ffd966; font-size:13px; }
    .goBack-btn { background:#2a4f8c; color:white; border:1px solid #fad57e; padding:6px 20px; border-radius:40px; cursor:pointer; font-weight:600; font-size:13px; transition:0.3s; }
    .goBack-btn:hover { background:#fad57e; color:#0b2447; }

    /* TYPE SWITCHER */
    .type-switcher { display:flex; gap:0; padding:20px 30px 0; }
    .type-btn { flex:1; padding:12px; border:2px solid #dee2e6; background:white; font-size:14px; font-weight:600; cursor:pointer; transition:0.3s; }
    .type-btn:first-child { border-radius:15px 0 0 15px; }
    .type-btn:last-child  { border-radius:0 15px 15px 0; }
    .type-btn.active-exp  { background:#e74c3c; color:white; border-color:#e74c3c; }
    .type-btn.active-rev  { background:#27ae60; color:white; border-color:#27ae60; }
    .type-btn:not(.active-exp):not(.active-rev):hover { background:#f0f4fa; }

    /* FORM BODY */
    .form-body { padding:24px 30px 30px; }

    /* INFO STRIP */
    .info-strip { background:#f0f4fa; border-radius:15px; padding:12px 18px; display:flex; gap:20px; flex-wrap:wrap; margin-bottom:22px; border-left:4px solid #1e2b4f; }
    .info-item { display:flex; align-items:center; gap:8px; font-size:13px; }
    .info-label { color:#6c757d; font-weight:600; }
    .info-value { color:#1e2b4f; font-weight:700; }

    /* SECTION */
    .section-title { font-size:13px; font-weight:700; color:#1e2b4f; text-transform:uppercase; letter-spacing:1px; margin:0 0 10px; display:flex; align-items:center; gap:6px; }
    .section-title::after { content:''; flex:1; height:1px; background:#e9f0fa; }

    /* GRID */
    .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
    .grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; }
    .grid-4 { display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:14px; }
    .full  { grid-column:1/-1; }

    /* FIELD */
    .field { display:flex; flex-direction:column; gap:5px; }
    .field label { font-size:12px; font-weight:600; color:#1e2b4f; }
    .field input, .field select {
      padding:10px 12px; border:2px solid #e9f0fa; border-radius:12px;
      font-size:14px; color:#2c3e50; background:white; transition:border-color 0.2s;
      width:100%;
    }
    .field input:focus, .field select:focus { outline:none; border-color:#1e2b4f; }
    .field input.err, .field select.err { border-color:#e74c3c; }
    .field .hint { font-size:11px; color:#aaa; }

    /* Combobox wrapper */
    .combo-wrap { position:relative; }
    .combo-wrap input { padding-right:32px; }
    .combo-arrow { position:absolute; right:10px; top:50%; transform:translateY(-50%); color:#888; cursor:pointer; font-size:12px; pointer-events:none; }
    .combo-dropdown {
      display:none; position:absolute; top:calc(100% + 3px); left:0; right:0; z-index:999;
      background:white; border:2px solid #1e2b4f; border-radius:12px; max-height:200px;
      overflow-y:auto; box-shadow:0 8px 24px rgba(0,0,0,0.15);
    }
    .combo-dropdown.open { display:block; }
    .combo-option { padding:9px 14px; cursor:pointer; font-size:14px; color:#2c3e50; }
    .combo-option:hover, .combo-option.highlighted { background:#e9f0fa; }
    .combo-option.no-match { color:#aaa; font-style:italic; }

    /* DATE FIELD */
    .date-wrap { position:relative; display:flex; gap:5px; align-items:center; }
    .date-text { flex:1; padding:10px 12px; border:2px solid #e9f0fa; border-radius:12px; font-size:14px; color:#2c3e50; background:white; transition:border-color 0.2s; }
    .date-text:focus { outline:none; border-color:#1e2b4f; }
    .cal-btn { padding:8px 10px; background:#1e2b4f; color:#ffd966; border:none; border-radius:10px; cursor:pointer; font-size:14px; }
    .cal-btn:hover { background:#2a3a60; }
    .date-native { position:fixed; left:-9999px; top:-9999px; width:1px; height:1px; opacity:0; }

    /* AMOUNT GRID */
    .amount-box { background:#f8f9fa; border-radius:15px; padding:16px; margin-bottom:18px; }
    .amount-box .grid-4 { gap:12px; }
    .currency-field { display:flex; flex-direction:column; gap:4px; }
    .currency-field label { font-size:11px; font-weight:700; color:#1e2b4f; text-align:center; }
    .currency-input-wrap { position:relative; }
    .currency-sym { position:absolute; left:10px; top:50%; transform:translateY(-50%); font-size:13px; font-weight:700; color:#888; pointer-events:none; }
    .currency-input-wrap input {
      padding:9px 9px 9px 26px; border:2px solid #e9f0fa; border-radius:10px;
      font-size:14px; color:#2c3e50; background:white; width:100%; transition:border-color 0.2s;
    }
    .currency-input-wrap input:focus { outline:none; border-color:#1e2b4f; }
    .currency-input-wrap.visa .currency-sym { color:#3498db; }
    .currency-row-label { grid-column:1/-1; font-size:11px; font-weight:700; color:#6c757d; text-transform:uppercase; letter-spacing:1px; padding-top:4px; }

    /* SUBMIT */
    .submit-area { display:flex; gap:12px; justify-content:flex-end; padding-top:10px; }
    .btn-submit { padding:12px 36px; border:none; border-radius:40px; font-size:15px; font-weight:700; cursor:pointer; transition:0.3s; }
    .btn-submit.exp { background:#e74c3c; color:white; }
    .btn-submit.exp:hover { background:#c0392b; transform:translateY(-1px); }
    .btn-submit.rev { background:#27ae60; color:white; }
    .btn-submit.rev:hover { background:#1e8449; transform:translateY(-1px); }
    .btn-reset { padding:12px 24px; border:2px solid #dee2e6; background:white; border-radius:40px; font-size:14px; font-weight:600; cursor:pointer; color:#6c757d; transition:0.3s; }
    .btn-reset:hover { border-color:#1e2b4f; color:#1e2b4f; }

    /* TOAST */
    .toast { position:fixed; bottom:30px; right:30px; padding:14px 24px; border-radius:15px; font-size:14px; font-weight:600; color:white; z-index:9999; box-shadow:0 8px 24px rgba(0,0,0,0.2); transform:translateY(80px); opacity:0; transition:0.4s cubic-bezier(.34,1.56,.64,1); pointer-events:none; }
    .toast.show { transform:translateY(0); opacity:1; }
    .toast.success { background:#27ae60; }
    .toast.error   { background:#e74c3c; }

    /* MODAL */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9998; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:white; border-radius:24px; padding:30px; width:380px; text-align:center; box-shadow:0 20px 50px rgba(0,0,0,0.3); }
    .modal-icon { font-size:48px; margin-bottom:12px; }
    .modal-msg  { font-size:16px; color:#1e2b4f; font-weight:600; margin-bottom:20px; line-height:1.5; }
    .modal-btn  { padding:10px 30px; background:#1e2b4f; color:#ffd966; border:none; border-radius:40px; font-size:14px; font-weight:700; cursor:pointer; }

    @media(max-width:640px) {
      .grid-4 { grid-template-columns:1fr 1fr; }
      .grid-3 { grid-template-columns:1fr 1fr; }
      .grid-2 { grid-template-columns:1fr; }
      .form-body { padding:16px; }
    }
  </style>
</head>
<body>

<div class="container">

  <!-- HEADER -->
  <div class="header">
    <h2>💰 Expense &amp; Revenue Entry</h2>
    <div class="user-info">
      <span class="user-badge" id="userBadge">—</span>
      <button class="goBack-btn" onclick="goBack()">🔙 رجوع</button>
    </div>
  </div>

  <!-- TYPE SWITCHER -->
  <div class="type-switcher">
    <button class="type-btn active-exp" id="btnExp" onclick="switchType('expense')">📤 Expense — مصروف</button>
    <button class="type-btn"            id="btnRev" onclick="switchType('revenue')">📥 Revenue / Funding — إيراد</button>
  </div>

  <div class="form-body">

    <!-- INFO STRIP -->
    <div class="info-strip">
      <div class="info-item"><span class="info-label">Center:</span><span class="info-value" id="infoCenter">—</span></div>
      <div class="info-item"><span class="info-label">Branch:</span><span class="info-value" id="infoBranch">—</span></div>
      <div class="info-item"><span class="info-label">User:</span><span class="info-value"  id="infoUser">—</span></div>
      <div class="info-item"><span class="info-label">Sheet:</span><span class="info-value" id="infoSheet" style="color:#e74c3c;">Expenses</span></div>
    </div>

    <!-- ROW 1: Date + Details + Account -->
    <div class="section-title">📋 Basic Info</div>
    <div class="grid-2" style="margin-bottom:14px;">

      <!-- Date -->
      <div class="field">
        <label>Date *</label>
        <div class="date-wrap">
          <input type="text" class="date-text" id="fDate" placeholder="dd/Mmm/yyyy" oninput="onDateType()" onblur="onDateBlur()">
          <button class="cal-btn" onclick="openCal()" type="button">📅</button>
          <input type="date" class="date-native" id="fDateNative" onchange="onCalPick()">
        </div>
      </div>

      <!-- Month / Year -->
      <div class="grid-2" style="gap:10px;">
        <div class="field">
          <label>Month *</label>
          <div class="combo-wrap">
            <input type="text" id="fMonth" placeholder="Month..." oninput="comboFilter('fMonth','monthOpts','monthDD')" onfocus="comboOpen('monthDD')" onblur="comboBlur('monthDD')" autocomplete="off">
            <span class="combo-arrow">▾</span>
            <div class="combo-dropdown" id="monthDD"></div>
          </div>
        </div>
        <div class="field">
          <label>Year *</label>
          <div class="combo-wrap">
            <input type="text" id="fYear" placeholder="Year..." oninput="comboFilter('fYear','yearOpts','yearDD')" onfocus="comboOpen('yearDD')" onblur="comboBlur('yearDD')" autocomplete="off">
            <span class="combo-arrow">▾</span>
            <div class="combo-dropdown" id="yearDD"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid-3" style="margin-bottom:18px;">
      <!-- Details -->
      <div class="field full" style="grid-column:span 1;">
        <label>Details — البيان *</label>
        <div class="combo-wrap">
          <input type="text" id="fDetails" placeholder="Search or type..." oninput="comboFilter('fDetails','detailsOpts','detailsDD')" onfocus="comboOpen('detailsDD')" onblur="comboBlur('detailsDD')" autocomplete="off">
          <span class="combo-arrow">▾</span>
          <div class="combo-dropdown" id="detailsDD"></div>
        </div>
      </div>
      <!-- Account -->
      <div class="field">
        <label>Account — المستفيد</label>
        <div class="combo-wrap">
          <input type="text" id="fAccount" placeholder="Search or type..." oninput="comboFilter('fAccount','accountOpts','accountDD')" onfocus="comboOpen('accountDD')" onblur="comboBlur('accountDD')" autocomplete="off">
          <span class="combo-arrow">▾</span>
          <div class="combo-dropdown" id="accountDD"></div>
        </div>
      </div>
      <!-- Account Type -->
      <div class="field">
        <label>Account Type — النوع</label>
        <div class="combo-wrap">
          <input type="text" id="fAccountType" placeholder="Search or type..." oninput="comboFilter('fAccountType','accountTypeOpts','accountTypeDD')" onfocus="comboOpen('accountTypeDD')" onblur="comboBlur('accountTypeDD')" autocomplete="off">
          <span class="combo-arrow">▾</span>
          <div class="combo-dropdown" id="accountTypeDD"></div>
        </div>
      </div>
    </div>

    <!-- AMOUNTS -->
    <div class="section-title">💵 Amounts — المبالغ</div>
    <div class="amount-box">
      <!-- Cash -->
      <div class="currency-row-label" style="margin-bottom:8px;">Cash — نقدي</div>
      <div class="grid-4" style="margin-bottom:14px;">
        <div class="currency-field">
          <label>USD $</label>
          <div class="currency-input-wrap">
            <span class="currency-sym">$</span>
            <input type="number" id="fUSD" placeholder="0" min="0" step="0.01">
          </div>
        </div>
        <div class="currency-field">
          <label>EUR €</label>
          <div class="currency-input-wrap">
            <span class="currency-sym">€</span>
            <input type="number" id="fEUR" placeholder="0" min="0" step="0.01">
          </div>
        </div>
        <div class="currency-field">
          <label>GBP £</label>
          <div class="currency-input-wrap">
            <span class="currency-sym">£</span>
            <input type="number" id="fGBP" placeholder="0" min="0" step="0.01">
          </div>
        </div>
        <div class="currency-field">
          <label>LE</label>
          <div class="currency-input-wrap">
            <span class="currency-sym" style="font-size:10px;">LE</span>
            <input type="number" id="fLE" placeholder="0" min="0" step="0.01">
          </div>
        </div>
      </div>
      <!-- Visa -->
      <div class="currency-row-label" style="margin-bottom:8px;">Visa / Card — فيزا</div>
      <div class="grid-4">
        <div class="currency-field">
          <label>Visa $</label>
          <div class="currency-input-wrap visa">
            <span class="currency-sym">$</span>
            <input type="number" id="fVUSD" placeholder="0" min="0" step="0.01">
          </div>
        </div>
        <div class="currency-field">
          <label>Visa €</label>
          <div class="currency-input-wrap visa">
            <span class="currency-sym">€</span>
            <input type="number" id="fVEUR" placeholder="0" min="0" step="0.01">
          </div>
        </div>
        <div class="currency-field">
          <label>Visa £</label>
          <div class="currency-input-wrap visa">
            <span class="currency-sym">£</span>
            <input type="number" id="fVGBP" placeholder="0" min="0" step="0.01">
          </div>
        </div>
        <div class="currency-field">
          <label>Visa LE</label>
          <div class="currency-input-wrap visa">
            <span class="currency-sym" style="font-size:10px;">LE</span>
            <input type="number" id="fVLE" placeholder="0" min="0" step="0.01">
          </div>
        </div>
      </div>
    </div>

    <!-- SUBMIT -->
    <div class="submit-area">
      <button class="btn-reset" onclick="resetForm()">🔄 Reset</button>
      <button class="btn-submit exp" id="btnSubmit" onclick="submitEntry()">💾 Save Expense</button>
    </div>

  </div><!-- /form-body -->
</div><!-- /container -->

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal-box">
    <div class="modal-icon" id="modalIcon">ℹ️</div>
    <div class="modal-msg"  id="modalMsg"></div>
    <button class="modal-btn" onclick="closeModal()">OK</button>
  </div>
</div>

<script>
  // ══════════════════════════════════════════════
  // CONFIG
  // ══════════════════════════════════════════════
  const GAS_URL = 'https://script.google.com/macros/s/AKfycbyB4ZzI5UJibARWEXXSmtLYACNWqiYvv1GC_zeeBsZFMcW7pOFskDDkbiNF50zdWorq/exec';
  const MONTHS  = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const YEARS   = ['2025','2026','2027','2028','2029','2030'];
  const DASHBOARD_PAGES = {
    Admin:'Dashboard.html', Owner:'OwnerDashboard.html',
    Sales:'SalesDashboard.html', Accountant:'AccountantDashboard.html'
  };

  // ══════════════════════════════════════════════
  // STATE
  // ══════════════════════════════════════════════
  let currentUser  = null;
  let currentType  = 'expense'; // 'expense' | 'revenue'
  let optionsCache = {};        // { expenses:{details,account,accountType}, revenues:{...} }

  // ══════════════════════════════════════════════
  // COMBO OPTIONS HOLDERS
  // ══════════════════════════════════════════════
  let detailsOpts     = [];
  let accountOpts     = [];
  let accountTypeOpts = [];
  const monthOpts     = MONTHS;
  const yearOpts      = YEARS;

  // ══════════════════════════════════════════════
  // TYPE SWITCHER
  // ══════════════════════════════════════════════
  function switchType(t) {
    currentType = t;
    document.getElementById('btnExp').className = 'type-btn' + (t==='expense'?' active-exp':'');
    document.getElementById('btnRev').className = 'type-btn' + (t==='revenue'?' active-rev':'');
    document.getElementById('infoSheet').textContent   = t==='expense' ? 'Expenses' : 'Other_Revenues';
    document.getElementById('infoSheet').style.color   = t==='expense' ? '#e74c3c'  : '#27ae60';
    document.getElementById('btnSubmit').className     = 'btn-submit ' + (t==='expense'?'exp':'rev');
    document.getElementById('btnSubmit').textContent   = t==='expense' ? '💾 Save Expense' : '💾 Save Revenue';
    // load options for the selected sheet
    loadSheetOptions(t);
  }

  // ══════════════════════════════════════════════
  // LOAD DROPDOWN OPTIONS FROM GAS
  // ══════════════════════════════════════════════
  function loadSheetOptions(type) {
    if (optionsCache[type]) {
      applyOptions(optionsCache[type]);
      return;
    }
    const sheet = type === 'expense' ? 'Expenses' : 'Other_Revenues';
    fetch(`${GAS_URL}?action=getSheetOptions&sheet=${sheet}`)
      .then(r => r.json())
      .then(data => {
        if (data && data.details) {
          optionsCache[type] = data;
          applyOptions(data);
        }
      })
      .catch(() => {
        // على الأقل المجاميع تبقى فارغة — لا توقف العمل
      });
  }

  function applyOptions(data) {
    detailsOpts     = data.details     || [];
    accountOpts     = data.account     || [];
    accountTypeOpts = data.accountType || [];
    // إعادة رسم الـ dropdowns المفتوحة إن وُجدت
    buildDD('detailsDD',     detailsOpts,     'fDetails');
    buildDD('accountDD',     accountOpts,     'fAccount');
    buildDD('accountTypeDD', accountTypeOpts, 'fAccountType');
  }

  // ══════════════════════════════════════════════
  // COMBOBOX ENGINE
  // ══════════════════════════════════════════════
  function buildDD(ddId, opts, inputId) {
    const val = (document.getElementById(inputId).value || '').toLowerCase();
    const filtered = opts.filter(o => o.toLowerCase().includes(val));
    const dd = document.getElementById(ddId);
    if (!filtered.length) {
      dd.innerHTML = '<div class="combo-option no-match">No match — type to add new</div>';
    } else {
      dd.innerHTML = filtered.map(o =>
        `<div class="combo-option" onmousedown="pickCombo('${inputId}','${ddId}','${o.replace(/'/g,"&#39;")}')">${o}</div>`
      ).join('');
    }
  }

  function comboFilter(inputId, optsVar, ddId) {
    const optsMap = { detailsOpts, accountOpts, accountTypeOpts, monthOpts, yearOpts };
    buildDD(ddId, optsMap[optsVar], inputId);
  }

  function comboOpen(ddId) {
    document.getElementById(ddId).classList.add('open');
  }
  function comboBlur(ddId) {
    setTimeout(() => document.getElementById(ddId).classList.remove('open'), 200);
  }
  function pickCombo(inputId, ddId, val) {
    document.getElementById(inputId).value = val;
    document.getElementById(ddId).classList.remove('open');
    document.getElementById(inputId).classList.remove('err');
  }

  // init static dropdowns
  function initStaticDD() {
    buildDD('monthDD', monthOpts, 'fMonth');
    buildDD('yearDD',  yearOpts,  'fYear');
  }

  // ══════════════════════════════════════════════
  // DATE
  // ══════════════════════════════════════════════
  function isoToDDMMM(iso) {
    if (!iso) return '';
    const [y,m,d] = iso.split('-');
    return `${d.padStart(2,'0')}/${MONTHS[Number(m)-1]}/${y}`;
  }
  function dddmmmToISO(t) {
    const m = t.match(/^(\d{1,2})\/([A-Za-z]{3})\/(\d{4})$/);
    if (!m) return '';
    const idx = MONTHS.findIndex(x => x.toLowerCase() === m[2].toLowerCase());
    if (idx < 0) return '';
    return `${m[3]}-${String(idx+1).padStart(2,'0')}-${m[1].padStart(2,'0')}`;
  }
  function todayISO() { return new Date().toISOString().split('T')[0]; }
  function todayDDMMM() { return isoToDDMMM(todayISO()); }

  function openCal() {
    const n = document.getElementById('fDateNative');
    n.style.pointerEvents = 'auto';
    try { n.showPicker(); } catch { n.click(); }
    setTimeout(() => { n.style.pointerEvents = 'none'; }, 2000);
  }
  function onCalPick() {
    const iso = document.getElementById('fDateNative').value;
    if (iso) {
      document.getElementById('fDate').value = isoToDDMMM(iso);
      document.getElementById('fDate').classList.remove('err');
      // auto-fill Month & Year
      const [y,,m] = iso.split('-');
      document.getElementById('fMonth').value = MONTHS[Number(m)-1];
      document.getElementById('fYear').value  = y;
    }
  }
  function onDateType() {
    const val = document.getElementById('fDate').value.trim();
    if (/^\d{1,2}\/[A-Za-z]{3}\/\d{4}$/.test(val)) {
      const iso = dddmmmToISO(val);
      if (iso) {
        document.getElementById('fDateNative').value = iso;
        document.getElementById('fDate').classList.remove('err');
        const [y,,m] = iso.split('-');
        document.getElementById('fMonth').value = MONTHS[Number(m)-1];
        document.getElementById('fYear').value  = y;
      }
    }
  }
  function onDateBlur() {
    const val = document.getElementById('fDate').value.trim();
    if (val && !/^\d{1,2}\/[A-Za-z]{3}\/\d{4}$/.test(val)) {
      document.getElementById('fDate').classList.add('err');
    }
  }

  // ══════════════════════════════════════════════
  // VALIDATE + COLLECT
  // ══════════════════════════════════════════════
  function collectRow() {
    const g = id => (document.getElementById(id).value || '').trim();
    const n = id => parseFloat(document.getElementById(id).value) || 0;
    return {
      date:        g('fDate'),
      details:     g('fDetails'),
      usd:         n('fUSD'),
      eur:         n('fEUR'),
      gbp:         n('fGBP'),
      le:          n('fLE'),
      vUSD:        n('fVUSD'),
      vEUR:        n('fVEUR'),
      vGBP:        n('fVGBP'),
      vLE:         n('fVLE'),
      account:     g('fAccount'),
      accountType: g('fAccountType'),
      month:       g('fMonth'),
      year:        g('fYear'),
      centerName:  currentUser?.centerName  || '',
      branchName:  currentUser?.branchName  || '',
      userID:      currentUser?.id          || currentUser?.name || ''
    };
  }

  function validate(row) {
    let ok = true;
    const req = [ ['fDate','date'], ['fDetails','details'] ];
    req.forEach(([id, key]) => {
      if (!row[key]) {
        document.getElementById(id).classList.add('err');
        ok = false;
      }
    });
    const amounts = [row.usd,row.eur,row.gbp,row.le,row.vUSD,row.vEUR,row.vGBP,row.vLE];
    if (amounts.every(v => !v)) {
      showToast('Enter at least one amount', 'error');
      ok = false;
    }
    if (row.date && !/^\d{1,2}\/[A-Za-z]{3}\/\d{4}$/.test(row.date)) {
      document.getElementById('fDate').classList.add('err');
      showToast('Invalid date format (dd/Mmm/yyyy)', 'error');
      ok = false;
    }
    return ok;
  }

  // ══════════════════════════════════════════════
  // SUBMIT
  // ══════════════════════════════════════════════
  function submitEntry() {
    const row = collectRow();
    if (!validate(row)) return;

    const sheet  = currentType === 'expense' ? 'Expenses' : 'Other_Revenues';
    const btn    = document.getElementById('btnSubmit');
    btn.disabled = true;
    btn.textContent = '⏳ Saving...';

    const payload = { action: 'addExpenseRevenue', sheet, row };

    fetch(GAS_URL, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload)
    })
    .then(r => r.json())
    .then(res => {
      if (res.success || res.status === 'ok') {
        showToast('✅ Saved successfully!', 'success');
        resetForm();
        // invalidate cache so next open re-fetches fresh options
        delete optionsCache[currentType];
      } else {
        showModal('❌', res.message || 'Save failed. Please try again.');
      }
    })
    .catch(err => {
      showModal('❌', 'Network error: ' + err.message);
    })
    .finally(() => {
      btn.disabled = false;
      btn.textContent = currentType==='expense' ? '💾 Save Expense' : '💾 Save Revenue';
    });
  }

  // ══════════════════════════════════════════════
  // RESET
  // ══════════════════════════════════════════════
  function resetForm() {
    const ids = ['fDate','fDetails','fAccount','fAccountType','fMonth','fYear',
                 'fUSD','fEUR','fGBP','fLE','fVUSD','fVEUR','fVGBP','fVLE'];
    ids.forEach(id => {
      const el = document.getElementById(id);
      el.value = '';
      el.classList.remove('err');
    });
    document.getElementById('fDateNative').value = '';
    // re-set date to today
    document.getElementById('fDate').value  = todayDDMMM();
    document.getElementById('fDateNative').value = todayISO();
    const d = new Date();
    document.getElementById('fMonth').value = MONTHS[d.getMonth()];
    document.getElementById('fYear').value  = String(d.getFullYear());
  }

  // ══════════════════════════════════════════════
  // UI HELPERS
  // ══════════════════════════════════════════════
  function showToast(msg, type='success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className   = `toast ${type} show`;
    setTimeout(() => { t.className = 'toast'; }, 3500);
  }
  function showModal(icon, msg) {
    document.getElementById('modalIcon').textContent = icon;
    document.getElementById('modalMsg').textContent  = msg;
    document.getElementById('modal').classList.add('open');
  }
  function closeModal() { document.getElementById('modal').classList.remove('open'); }

  function goBack() { window.location.href = DASHBOARD_PAGES[currentUser?.type] || 'Dashboard.html'; }

  // ══════════════════════════════════════════════
  // INIT
  // ══════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', () => {
    // get user
    let ud = sessionStorage.getItem('currentUser');
    if (!ud) {
      try {
        const p = new URLSearchParams(window.location.search).get('user');
        if (p) { ud = decodeURIComponent(p); sessionStorage.setItem('currentUser', ud); }
      } catch {}
    }
    if (!ud) { window.location.href = 'index.html'; return; }
    try { currentUser = JSON.parse(ud); } catch { window.location.href = 'index.html'; return; }

    // populate info strip
    document.getElementById('userBadge').textContent  = currentUser.name || 'User';
    document.getElementById('infoCenter').textContent = currentUser.centerName || '—';
    document.getElementById('infoBranch').textContent = currentUser.branchName || '—';
    document.getElementById('infoUser').textContent   = currentUser.name || currentUser.id || '—';

    // set today
    document.getElementById('fDate').value       = todayDDMMM();
    document.getElementById('fDateNative').value = todayISO();
    const d = new Date();
    document.getElementById('fMonth').value = MONTHS[d.getMonth()];
    document.getElementById('fYear').value  = String(d.getFullYear());

    // init static combos
    initStaticDD();
    buildDD('monthDD', monthOpts, 'fMonth');
    buildDD('yearDD',  yearOpts,  'fYear');

    // load expense options by default
    loadSheetOptions('expense');
  });

  // expose globals
  window.switchType     = switchType;
  window.openCal        = openCal;
  window.onCalPick      = onCalPick;
  window.onDateType     = onDateType;
  window.onDateBlur     = onDateBlur;
  window.comboFilter    = comboFilter;
  window.comboOpen      = comboOpen;
  window.comboBlur      = comboBlur;
  window.pickCombo      = pickCombo;
  window.submitEntry    = submitEntry;
  window.resetForm      = resetForm;
  window.goBack         = goBack;
  window.closeModal     = closeModal;
</script>
</body>
</html>
